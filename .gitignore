# ============================================
# EXCLUDE (force include files via git add -f)
# ============================================
# Important: Files below should NOT be ignored
# Use them with git add -f if needed

# !.env.example       # Keep example env file
# !MIGRATION_GUIDE.md # Keep migration docs
# !/scripts/          # Keep scripts folder
