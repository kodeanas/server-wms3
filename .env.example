# ===========================
# PostgreSQL Database Configuration
# ===========================
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=wms_db
DB_PORT=5432
DB_SSLMODE=disable

# Connection Pool Settings
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# ===========================
# Gin Web Framework Configuration
# ===========================
PORT=8080
GIN_MODE=debug

# ===========================
# API Configuration
# ===========================
API_TIMEOUT=30
API_HOST=localhost
API_VERSION=v1

# ===========================
# Environment
# ===========================
ENVIRONMENT=development

